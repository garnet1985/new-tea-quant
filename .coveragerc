[run]
source = core
omit = 
    */__test__/*
    */__pycache__/*
    */venv/*
    */userspace/*
    */test_*.py
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
