{
    "_comment": "框架默认配置，不应修改。用户可以通过 custom/mapping.json 覆盖",
    "data_sources": {
        "stock_list": {
            "handler": "handlers.stock_list.TushareStockListHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "api_fields": "ts_code,symbol,name,area,industry,market,exchange,list_date"
            }
        },
        "kline": {
            "handler": "handlers.kline.KlineHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": true,
                "stock_list": true
            },
            "params": {}
        },
        "corporate_finance": {
            "handler": "handlers.corporate_finance.CorporateFinanceHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": true,
                "stock_list": true
            },
            "params": {}
        },
        "gdp": {
            "handler": "handlers.rolling.RollingHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "provider_name": "tushare",
                "method": "get_gdp",
                "date_format": "quarter",
                "default_date_range": {"years": 5},
                "rolling_periods": 4,
                "field_mapping": {
                    "quarter": "quarter",
                    "gdp": "gdp",
                    "gdp_yoy": "gdp_yoy",
                    "primary_industry": "pi",
                    "primary_industry_yoy": "pi_yoy",
                    "secondary_industry": "si",
                    "secondary_industry_yoy": "si_yoy",
                    "tertiary_industry": "ti",
                    "tertiary_industry_yoy": "ti_yoy"
                }
            }
        },
        "price_indexes": {
            "handler": "handlers.price_indexes.PriceIndexesHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "default_date_range": {"years": 3},
                "rolling_months": 12
            }
        },
        "shibor": {
            "handler": "handlers.rolling.RollingHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "provider_name": "tushare",
                "method": "get_shibor",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "rolling_periods": 30,
                "field_mapping": {
                    "date": "date",
                    "one_night": "on",
                    "one_week": "1w",
                    "one_month": "1m",
                    "three_month": "3m",
                    "one_year": "1y"
                }
            }
        },
        "lpr": {
            "handler": "handlers.rolling.RollingHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "provider_name": "tushare",
                "method": "get_lpr",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "rolling_periods": 30,
                "field_mapping": {
                    "date": "date",
                    "lpr_1_y": "1y",
                    "lpr_5_y": "5y"
                }
            }
        },
        "latest_trading_date": {
            "handler": "handlers.latest_trading_date.LatestTradingDateHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "backward_checking_days": 15
            }
        },
        "adj_factor_event": {
            "handler": "handlers.adj_factor_event.AdjFactorEventHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": true,
                "stock_list": true
            },
            "params": {
                "update_threshold_days": 15,
                "max_workers": 10
            }
        },
        "industry_capital_flow": {
            "handler": "handlers.industry_capital_flow.IndustryCapitalFlowHandler",
            "is_enabled": false,
            "dependencies": {
                "latest_completed_trading_date": false,
                "stock_list": false
            },
            "params": {
                "default_date_range": { "start_date": "20080101" }
            }
        },
        "stock_index_indicator": {
            "handler": "handlers.stock_index_indicator.StockIndexIndicatorHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": true,
                "stock_list": false
            },
            "params": {
                "index_list": [
                    {"id": "000001.SH", "name": "上证指数"},
                    {"id": "000300.SH", "name": "沪深300"},
                    {"id": "000688.SH", "name": "科创50"},
                    {"id": "399001.SZ", "name": "深证成指"},
                    {"id": "399006.SZ", "name": "创业板指"}
                ]
            }
        },
        "stock_index_indicator_weight": {
            "handler": "handlers.stock_index_indicator_weight.StockIndexIndicatorWeightHandler",
            "is_enabled": true,
            "dependencies": {
                "latest_completed_trading_date": true,
                "stock_list": false
            },
            "params": {
                "index_list": [
                    {"id": "000001.SH", "name": "上证指数"},
                    {"id": "000300.SH", "name": "沪深300"},
                    {"id": "000688.SH", "name": "科创50"},
                    {"id": "399001.SZ", "name": "深证成指"},
                    {"id": "399006.SZ", "name": "创业板指"}
                ]
            }
        }
    }
}

