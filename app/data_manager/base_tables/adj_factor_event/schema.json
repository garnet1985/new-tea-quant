{
    "name": "adj_factor_event",
    "primaryKey": ["id", "event_date"],
    "fields": [
        {
            "name": "id",
            "type": "varchar",
            "length": 16,
            "isRequired": true,
            "description": "股票代码（含市场后缀，如000001.SZ）"
        },
        {
            "name": "event_date",
            "type": "varchar",
            "length": 8,
            "isRequired": true,
            "description": "除权除息日期（YYYYMMDD）"
        },
        {
            "name": "tushare_factor",
            "type": "float",
            "isRequired": true,
            "description": "Tushare复权因子 F(t)，用于计算前复权价格"
        },
        {
            "name": "qfq_diff",
            "type": "float",
            "isRequired": false,
            "default": 0.0,
            "description": "与EastMoney前复权价格的固定差异（qfq_diff），只在除权日更新"
        },
        {
            "name": "last_update",
            "type": "datetime",
            "isRequired": true,
            "default": "CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
            "description": "记录最后更新时间"
        }
    ],
    "indexes": [
        {
            "name": "idx_id_event_date",
            "fields": ["id", "event_date"],
            "unique": true
        },
        {
            "name": "idx_id",
            "fields": ["id"]
        },
        {
            "name": "idx_event_date",
            "fields": ["event_date"]
        },
        {
            "name": "idx_id_date_desc",
            "fields": ["id", "event_date"],
            "unique": false,
            "description": "用于查询最近的有效因子（ORDER BY event_date DESC）"
        }
    ],
    "description": "复权因子事件表，只存储复权因子变化的日期（除权除息日），不存储每日因子。用于优化存储和计算前复权价格。"
}

