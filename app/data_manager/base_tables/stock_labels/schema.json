{
    "name": "stock_labels",
    "primaryKey": ["stock_id", "label_date"],
    "fields": [
        {
            "name": "stock_id",
            "type": "varchar",
            "length": 20,
            "isRequired": true,
            "description": "股票代码"
        },
        {
            "name": "label_date",
            "type": "date",
            "isRequired": true,
            "description": "标签计算日期"
        },
        {
            "name": "labels",
            "type": "text",
            "isRequired": true,
            "description": "标签ID字符串，用逗号分隔"
        }
    ]
}
