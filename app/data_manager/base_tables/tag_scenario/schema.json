{
  "name": "tag_scenario",
  "primaryKey": "id",
  "fields": [
    {
      "name": "id",
      "type": "bigint",
      "isRequired": true,
      "isAutoIncrement": true,
      "description": "自增主键"
    },
    {
      "name": "name",
      "type": "varchar",
      "length": 64,
      "isRequired": true,
      "description": "业务场景唯一代码（如 market_value_bucket, momentum_classifier）"
    },
    {
      "name": "display_name",
      "type": "varchar",
      "length": 128,
      "isRequired": false,
      "description": "业务场景显示名称"
    },
    {
      "name": "version",
      "type": "varchar",
      "length": 32,
      "isRequired": true,
      "description": "版本号（用户显式声明，用于版本管理，如 \"1.0\", \"2.0\"）。代表整个业务场景的算法版本"
    },
    {
      "name": "description",
      "type": "text",
      "isRequired": false,
      "description": "业务场景描述（用于文档和说明）"
    },
    {
      "name": "is_legacy",
      "type": "tinyint",
      "length": 1,
      "isRequired": true,
      "default": 0,
      "description": "是否为遗留业务场景（0: 否，1: 是）"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "isRequired": true,
      "default": "CURRENT_TIMESTAMP",
      "description": "创建时间"
    },
    {
      "name": "updated_at",
      "type": "datetime",
      "isRequired": true,
      "default": "CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
      "description": "更新时间"
    }
  ],
  "indexes": [
    {
      "name": "uk_name_version",
      "fields": ["name", "version"],
      "isUnique": true,
      "description": "唯一索引：同一场景的不同版本（允许一个场景有多个版本）"
    },
    {
      "name": "idx_name",
      "fields": ["name"],
      "description": "业务场景名称索引（用于快速查找）"
    }
  ]
}
