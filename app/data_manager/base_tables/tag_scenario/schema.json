{
  "name": "tag_scenario",
  "primaryKey": "id",
  "fields": [
    {
      "name": "id",
      "type": "bigint",
      "isRequired": true,
      "isAutoIncrement": true,
      "description": "自增主键"
    },
    {
      "name": "name",
      "type": "varchar",
      "length": 64,
      "isRequired": true,
      "description": "业务场景唯一代码（如 market_value_bucket, momentum_classifier）"
    },
    {
      "name": "display_name",
      "type": "varchar",
      "length": 128,
      "isRequired": false,
      "description": "业务场景显示名称"
    },
    {
      "name": "description",
      "type": "text",
      "isRequired": false,
      "description": "业务场景描述（用于文档和说明）"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "isRequired": true,
      "default": "CURRENT_TIMESTAMP",
      "description": "创建时间"
    },
    {
      "name": "updated_at",
      "type": "datetime",
      "isRequired": true,
      "default": "CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
      "description": "更新时间"
    }
  ],
  "indexes": [
    {
      "name": "uk_name",
      "fields": ["name"],
      "isUnique": true,
      "description": "唯一索引：业务场景名称唯一（一个场景只有一个记录）"
    }
  ]
}
