{
    "_comment": "框架默认配置，不应修改。用户可以通过 custom/mapping.json 覆盖",
    "data_sources": {
        "stock_list": {
            "handler": "defaults.handlers.stock_list_handler.TushareStockListHandler",
            "is_enabled": true,
            "params": {
                "api_fields": "ts_code,symbol,name,area,industry,market,exchange,list_date"
            }
        },
        "kline": {
            "handler": "defaults.handlers.kline_handler.KlineHandler",
            "is_enabled": true,
            "params": {}
        },
        "corporate_finance": {
            "handler": "defaults.handlers.corporate_finance_handler.CorporateFinanceHandler",
            "is_enabled": true,
            "params": {}
        },
        "gdp": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_gdp",
                "date_format": "quarter",
                "default_date_range": {"years": 5},
                "field_mapping": {
                    "quarter": "quarter",
                    "gdp": "gdp",
                    "gdp_yoy": "gdp_yoy",
                    "primary_industry": "pi",
                    "primary_industry_yoy": "pi_yoy",
                    "secondary_industry": "si",
                    "secondary_industry_yoy": "si_yoy",
                    "tertiary_industry": "ti",
                    "tertiary_industry_yoy": "ti_yoy"
                }
            }
        },
        "price_indexes": {
            "handler": "defaults.handlers.price_indexes_handler.PriceIndexesHandler",
            "is_enabled": true,
            "params": {
                "default_date_range": {"years": 3}
            }
        },
        "shibor": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_shibor",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "field_mapping": {
                    "date": "date",
                    "one_night": "on",
                    "one_week": "1w",
                    "one_month": "1m",
                    "three_month": "3m",
                    "one_year": "1y"
                }
            }
        },
        "lpr": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_lpr",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "field_mapping": {
                    "date": "date",
                    "lpr_1_y": "1y",
                    "lpr_5_y": "5y"
                }
            }
        },
        "latest_trading_date": {
            "handler": "defaults.handlers.latest_trading_date_handler.LatestTradingDateHandler",
            "is_enabled": true,
            "params": {
                "backward_checking_days": 15
            }
        },
        "adj_factor_event": {
            "handler": "defaults.handlers.adj_factor_event_handler.AdjFactorEventHandler",
            "is_enabled": true,
            "params": {
                "update_threshold_days": 15,
                "max_workers": 10
            }
        }
    }
}

