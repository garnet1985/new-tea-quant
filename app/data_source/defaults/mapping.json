{
    "_comment": "框架默认配置，不应修改。用户可以通过 custom/mapping.json 覆盖",
    "data_sources": {
        "stock_list": {
            "handler": "defaults.handlers.stock_list_handler.TushareStockListHandler",
            "is_enabled": true,
            "params": {
                "api_fields": "ts_code,symbol,name,area,industry,market,exchange,list_date"
            }
        },
        "daily_kline": {
            "handler": "defaults.handlers.daily_kline_handler.DailyKlineHandler",
            "is_enabled": true,
            "params": {}
        },
        "weekly_kline": {
            "handler": "defaults.handlers.weekly_kline_handler.WeeklyKlineHandler",
            "is_enabled": true,
            "params": {}
        },
        "monthly_kline": {
            "handler": "defaults.handlers.monthly_kline_handler.MonthlyKlineHandler",
            "is_enabled": true,
            "params": {}
        },
        "corporate_finance": {
            "handler": "defaults.handlers.corporate_finance_handler.CorporateFinanceHandler",
            "is_enabled": true,
            "params": {}
        },
        "gdp": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_gdp",
                "date_format": "quarter",
                "default_date_range": {"years": 5},
                "field_mapping": {
                    "quarter": "quarter",
                    "gdp": "gdp",
                    "gdp_yoy": "gdp_yoy",
                    "primary_industry": "pi",
                    "primary_industry_yoy": "pi_yoy",
                    "secondary_industry": "si",
                    "secondary_industry_yoy": "si_yoy",
                    "tertiary_industry": "ti",
                    "tertiary_industry_yoy": "ti_yoy"
                }
            }
        },
        "cpi": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_cpi",
                "date_format": "month",
                "default_date_range": {"years": 3},
                "field_mapping": {
                    "date": "month",
                    "cpi": "nt_val",
                    "cpi_yoy": "nt_yoy",
                    "cpi_mom": "nt_mom"
                }
            }
        },
        "ppi": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_ppi",
                "date_format": "month",
                "default_date_range": {"years": 3},
                "field_mapping": {
                    "date": "month",
                    "ppi": "ppi_accu",
                    "ppi_yoy": "ppi_yoy",
                    "ppi_mom": "ppi_mom"
                }
            }
        },
        "pmi": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_pmi",
                "date_format": "month",
                "default_date_range": {"years": 3},
                "field_mapping": {
                    "date": "MONTH",
                    "pmi": "PMI010000",
                    "pmi_l_scale": "PMI010100",
                    "pmi_m_scale": "PMI010200",
                    "pmi_s_scale": "PMI010300"
                }
            }
        },
        "shibor": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_shibor",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "field_mapping": {
                    "date": "date",
                    "one_night": "on",
                    "one_week": "1w",
                    "one_month": "1m",
                    "three_month": "3m",
                    "one_year": "1y"
                }
            }
        },
        "lpr": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_lpr",
                "date_format": "date",
                "default_date_range": {"years": 1},
                "field_mapping": {
                    "date": "date",
                    "lpr_1_y": "1y",
                    "lpr_5_y": "5y"
                }
            }
        },
        "money_supply": {
            "handler": "defaults.handlers.simple_api_handler.SimpleApiHandler",
            "is_enabled": true,
            "params": {
                "provider_name": "tushare",
                "method": "get_money_supply",
                "date_format": "month",
                "default_date_range": {"years": 3},
                "field_mapping": {
                    "date": "month",
                    "m0": "m0",
                    "m0_yoy": "m0_yoy",
                    "m0_mom": "m0_mom",
                    "m1": "m1",
                    "m1_yoy": "m1_yoy",
                    "m1_mom": "m1_mom",
                    "m2": "m2",
                    "m2_yoy": "m2_yoy",
                    "m2_mom": "m2_mom"
                }
            }
        },
        "latest_trading_date": {
            "handler": "defaults.handlers.latest_trading_date_handler.LatestTradingDateHandler",
            "is_enabled": true,
            "params": {
                "backward_checking_days": 15
            }
        },
        "adj_factor": {
            "handler": "defaults.handlers.adj_factor_handler.AdjFactorHandler",
            "is_enabled": true,
            "params": {}
        }
    }
}

