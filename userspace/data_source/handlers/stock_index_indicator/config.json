{
    "_comment": "Stock Index Indicator Handler 配置",
    "renew_mode": "incremental",
    "date_format": "day",
    "default_date_range": {
        "years": 5
    },
    "table_name": "stock_index_indicator",
    "date_field": "date",
    "index_list": [
        {"id": "000001.SH", "name": "上证指数"},
        {"id": "000300.SH", "name": "沪深300"},
        {"id": "000688.SH", "name": "科创50"},
        {"id": "399001.SZ", "name": "深证成指"},
        {"id": "399006.SZ", "name": "创业板指"}
    ],
    "apis": {
        "daily_kline": {
            "provider_name": "tushare",
            "method": "get_index_daily",
            "max_per_minute": 500,
            "field_mapping": {
                "date": "trade_date",
                "open": "open",
                "close": "close",
                "highest": "high",
                "lowest": "low",
                "pre_close": "pre_close",
                "price_change_delta": "change",
                "price_change_rate_delta": "pct_chg",
                "volume": "vol",
                "amount": "amount"
            },
            "params": {},
            "group_by": "ts_code"
        },
        "weekly_kline": {
            "provider_name": "tushare",
            "method": "get_index_weekly",
            "max_per_minute": 500,
            "field_mapping": {
                "date": "trade_date",
                "open": "open",
                "close": "close",
                "highest": "high",
                "lowest": "low",
                "pre_close": "pre_close",
                "price_change_delta": "change",
                "price_change_rate_delta": "pct_chg",
                "volume": "vol",
                "amount": "amount"
            },
            "params": {},
            "group_by": "ts_code"
        },
        "monthly_kline": {
            "provider_name": "tushare",
            "method": "get_index_monthly",
            "max_per_minute": 500,
            "field_mapping": {
                "date": "trade_date",
                "open": "open",
                "close": "close",
                "highest": "high",
                "lowest": "low",
                "pre_close": "pre_close",
                "price_change_delta": "change",
                "price_change_rate_delta": "pct_chg",
                "volume": "vol",
                "amount": "amount"
            },
            "params": {},
            "group_by": "ts_code"
        }
    }
}
