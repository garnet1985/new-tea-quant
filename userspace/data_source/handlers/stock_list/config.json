{
    "_comment": "Stock List Handler 配置",

    "renew": {
        "type": "refresh"
    },

    "apis": {
        "stock_list_data": {
            "provider_name": "tushare",
            "method": "get_stock_list",
            "max_per_minute": 10,
            "field_mapping": {
                "id": "ts_code",
                "name": "name",
                "industry": "industry",
                "type": "market",
                "exchange_center": "exchange"
            },
            "params": {
                "fields": "ts_code,symbol,name,area,industry,market,exchange,list_date"
            }
        }
    }
}
