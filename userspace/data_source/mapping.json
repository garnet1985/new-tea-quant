{
    "_comment": "用户自定义配置。handler 路径必须为「模块.类名」格式（如 kline.KlineHandler），框架从 userspace/data_source/handlers/<模块>/handler.py 加载该类；不再支持按路径自动推断类名。is_enabled、depends_on 见下。",
    "_comment_depends_on": "depends_on: 数据源依赖（需要先执行的数据源），格式为数组，如 [\"stock_list\", \"latest_trading_date\"]。依赖的数据源会先执行并更新数据库，然后当前 handler 才能使用最新的数据。",
    "data_sources": {
        "stock_list": {
            "handler": "stock_list.TushareStockListHandler",
            "is_enabled": true
        },
        "latest_trading_date": {
            "handler": "latest_trading_date.LatestTradingDateHandler",
            "is_enabled": true
        },
        "kline": {
            "handler": "kline.KlineHandler",
            "is_enabled": false,
            "depends_on": ["stock_list", "latest_trading_date"]
        },
        "stock_indicators": {
            "handler": "stock_indicators.StockIndicatorsHandler",
            "is_enabled": false,
            "depends_on": ["stock_list", "latest_trading_date"]
        },
        "corporate_finance": {
            "handler": "corporate_finance.CorporateFinanceHandler",
            "is_enabled": false,
            "depends_on": ["stock_list", "latest_trading_date"]
        },
        "adj_factor_event": {
            "handler": "adj_factor_event.AdjFactorEventHandler",
            "is_enabled": false,
            "depends_on": ["stock_list", "latest_trading_date"]
        },
        "index_klines": {
            "handler": "index_klines.IndexKlinesHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "index_weight": {
            "handler": "index_weight.IndexWeightHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "gdp": {
            "handler": "gdp.GdpHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "cpi": {
            "handler": "cpi.CpiHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "ppi": {
            "handler": "ppi.PpiHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "pmi": {
            "handler": "pmi.PmiHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "money_supply": {
            "handler": "money_supply.MoneySupplyHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "shibor": {
            "handler": "shibor.ShiborHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        },
        "lpr": {
            "handler": "lpr.LprHandler",
            "is_enabled": false,
            "depends_on": ["latest_trading_date"]
        }
    }
}
